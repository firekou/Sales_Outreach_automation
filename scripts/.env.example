# AI Token King — LinkedIn 自動化系統環境設定
# 複製此檔為 .env，填入真實值後執行腳本
# ⚠ 請勿將 .env 提交到 Git

# ── Anthropic API Key（訊息草稿生成）────────────────────────
# 取得方式：https://console.anthropic.com → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Apify API Token（LinkedIn 抓取）─────────────────────────
# 取得方式：https://console.apify.com/account/integrations → API tokens
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LinkedIn Session Cookie（li_at）─────────────────────────
# 取得方式（Chrome）：登入 LinkedIn → F12 → Application → Cookies → linkedin.com → li_at
# 注意：li_at 約 1 年有效，帳號登出後即失效
LINKEDIN_LI_AT=AQEDAQ...（你的 li_at 值）

# ── Asana CRM 整合（去重 + Task 建立）───────────────────────
# ASANA_TOKEN：Asana → My Settings → Apps → Personal Access Tokens → Create token
ASANA_TOKEN=1/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ASANA_PROJECT_GID：LinkedIn CRM 專案的 GID（Asana 專案 URL 中的數字）
# 例：https://app.asana.com/0/1234567890123456/... → GID 為 1234567890123456
ASANA_PROJECT_GID=1234567890123456

# ── Make.com Webhook（自動發送觸發器）───────────────────────
# 在 Make.com 建立 Webhook → 複製 URL 貼此
# 用途：linkedin_processor.py webhook 指令 + 草稿審核後自動觸發
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Slack Webhook（Hot Lead 即時通知）───────────────────────
# Slack → App 管理 → Incoming Webhooks → 新增 Webhook → 複製 URL
# 用途：Hot Lead 回覆偵測後立即推播 #leads-直銷 或 #leads-通路
# 格式：https://hooks.slack.com/services/WORKSPACE_ID/CHANNEL_ID/TOKEN
SLACK_WEBHOOK_URL=填入你的 Slack Incoming Webhook URL
